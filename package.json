{
  "name": "necobot-ultimus",
  "version": "1.0.0",
  "description": "Discord bot with necoarc personality and multiple features",
  "main": "dist/app.js",
  "scripts": {
    "test": "vitest",
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "db:migrate": "drizzle-kit migrate --config=db/config/drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=db/config/drizzle.config.ts"
  },
  "author": "Manuel Soler Juan",
  "type": "module",
  "dependencies": {
    "luxon": "^3.7.2",
    "pino": "^10.3.1",
    "undici": "^8.4.1",
    "bullmq": "^5.78.0",
    "dotenv": "^17.4.2",
    "discord.js": "^14.26.4",
    "drizzle-orm": "^0.45.2",
    "better-sqlite3": "^12.10.0",
    "discord-api-types": "^0.38.48",
    "@sapphire/framework": "^5.5.0",
    "@sapphire/shapeshift": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "vitest": "^4.1.8",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.3",
    "pino-pretty": "^13.1.3",
    "drizzle-kit": "^0.31.10",
    "@types/better-sqlite3": "^7.6.13"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
