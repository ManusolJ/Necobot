{
  "name": "necobot-ultimus",
  "version": "1.0.0",
  "description": "Discord bot with necoarc personality and multiple features",
  "main": "dist/app.js",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate --name"
  },
  "author": "Manuel Soler Juan",
  "type": "module",
  "dependencies": {
    "@sapphire/framework": "^5.5.0",
    "@sapphire/plugin-scheduled-tasks": "^10.0.4",
    "@sapphire/shapeshift": "^4.0.0",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.78.0",
    "discord-api-types": "^0.38.48",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "luxon": "^3.7.2",
    "pino": "^10.3.1",
    "undici": "^8.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.10.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
